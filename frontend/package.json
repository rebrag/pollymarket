{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "prepare-env": "node scripts/generate-environment.cjs",
    "prestart": "npm run prepare-env",
    "prebuild": "npm run prepare-env",
    "prewatch": "npm run prepare-env",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.11",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@spartan-ng/ui-formfield-brain": "^0.0.1-alpha.374",
    "@spartan-ng/ui-forms-brain": "^0.0.1-alpha.374",
    "@spartan-ng/ui-label-brain": "^0.0.1-alpha.374",
    "chart.js": "^4.5.1",
    "ng2-charts": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.19",
    "@angular/cli": "^20.3.19",
    "@angular/compiler-cli": "^20.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.2"
  }
}
